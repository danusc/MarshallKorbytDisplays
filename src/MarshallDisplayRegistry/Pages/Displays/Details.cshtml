@page "{id:int}"
@model MarshallDisplayRegistry.Pages.Displays.DetailsModel
@{
    ViewData["Title"] = Model.Device?.ComputerName ?? "Display";
}

@if (Model.Device is not null)
{
    <div class="page-title">
        <div>
            <h1 class="h3 mb-1">@Model.Device.ComputerName</h1>
            <p class="text-muted mb-0">@Model.Device.FriendlyName</p>
        </div>
        <div>
            <a class="btn btn-outline-secondary" asp-page="Edit" asp-route-id="@Model.Device.Id">Edit</a>
            <a class="btn btn-outline-secondary" asp-page="Index">Back</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert alert-info">@Model.Message</div>
    }

    <div class="summary-grid">
        <div class="summary-tile">
            <span class="text-muted">Status</span><br />
            <span class="status-pill @Model.StatusCss">@Model.Status</span>
        </div>
        <div class="summary-tile">
            <span class="value">@(Model.Device.ChromeRunning ? "Yes" : "No")</span>
            <span class="text-muted">Chrome running</span>
        </div>
        <div class="summary-tile">
            <span class="value">@(Model.Device.LastSeenUtc?.ToLocalTime().ToString("g") ?? "Never")</span>
            <span class="text-muted">Last seen</span>
        </div>
    </div>

    <div class="form-panel mb-3">
        <dl class="metadata-grid mb-0">
            <div><dt>Desired URL</dt><dd>@Model.Device.DesiredUrl</dd></div>
            <div><dt>Current URL</dt><dd>@Model.Device.CurrentUrl</dd></div>
            <div><dt>Building</dt><dd>@Model.Device.Building</dd></div>
            <div><dt>Room</dt><dd>@Model.Device.Room</dd></div>
            <div><dt>Location</dt><dd>@Model.Device.Location</dd></div>
            <div><dt>Serial number</dt><dd>@Model.Device.SerialNumber</dd></div>
            <div><dt>MAC address</dt><dd>@Model.Device.MacAddress</dd></div>
            <div><dt>Agent version</dt><dd>@Model.Device.AgentVersion</dd></div>
            <div><dt>Last error</dt><dd>@Model.Device.LastError</dd></div>
        </dl>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-lg-7">
            <form method="post" asp-page-handler="Assign" class="form-panel">
                <h2 class="h5">Assign URL Profile</h2>
                <input type="hidden" name="id" value="@Model.Device.Id" />
                <div class="mb-2">
                    <label class="form-label" for="urlProfileId">URL profile</label>
                    <select class="form-select" id="urlProfileId" name="urlProfileId">
                        @foreach (var profile in Model.UrlProfiles)
                        {
                            <option value="@profile.Id">@profile.Name - @profile.Url</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="notes">Notes</label>
                    <input class="form-control" id="notes" name="notes" />
                </div>
                <button class="btn btn-primary" type="submit">Assign</button>
            </form>
        </div>
        <div class="col-lg-5">
            <div class="form-panel">
                <h2 class="h5">Device Commands</h2>
                <form method="post" asp-page-handler="QueueRestart" asp-route-id="@Model.Device.Id">
                    <button class="btn btn-warning" type="submit">Queue RestartChrome</button>
                </form>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="table-shell">
                <table class="table table-sm mb-0">
                    <thead class="table-light"><tr><th>Recent check-ins</th><th>URL</th><th>Error</th></tr></thead>
                    <tbody>
                    @foreach (var checkIn in Model.RecentCheckIns)
                    {
                        <tr>
                            <td>@checkIn.CheckInUtc.ToLocalTime().ToString("g")</td>
                            <td class="url-cell">@checkIn.CurrentUrl</td>
                            <td>@checkIn.ErrorMessage</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="table-shell">
                <table class="table table-sm mb-0">
                    <thead class="table-light"><tr><th>Recent commands</th><th>Status</th><th>Result</th></tr></thead>
                    <tbody>
                    @foreach (var command in Model.RecentCommands)
                    {
                        <tr>
                            <td>@command.CommandType<br /><span class="text-muted">@command.CreatedUtc.ToLocalTime().ToString("g")</span></td>
                            <td>@command.Status</td>
                            <td>@command.ResultMessage</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
