@page
@model MarshallDisplayRegistry.Pages.Displays.IndexModel
@{
    ViewData["Title"] = "Displays";
}

<div class="page-title">
    <div>
        <h1 class="h3 mb-1">Displays</h1>
        <p class="text-muted mb-0">Registered Windows public display computers.</p>
    </div>
    <a class="btn btn-primary" asp-page="Edit">Add Display</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-sm-8 col-md-5">
        <input class="form-control" name="search" value="@Model.Search" placeholder="Search computer, room, building, or location" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
</form>

<div class="table-shell">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Computer</th>
                <th>Status</th>
                <th>Location</th>
                <th>Desired URL</th>
                <th>Last seen</th>
                <th>Enabled</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var device in Model.Displays)
        {
            <tr>
                <td>
                    <strong>@device.ComputerName</strong><br />
                    <span class="text-muted">@device.FriendlyName</span>
                </td>
                <td><span class="status-pill @device.StatusCss">@device.Status</span></td>
                <td>@device.LocationSummary</td>
                <td class="url-cell">@device.DesiredUrl</td>
                <td>@device.LastSeen</td>
                <td>@(device.Enabled ? "Yes" : "No")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@device.Id">Details</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@device.Id">Edit</a>
                    <form method="post" asp-page-handler="Toggle" asp-route-id="@device.Id" class="d-inline">
                        <button class="btn btn-sm btn-outline-warning" type="submit">@(device.Enabled ? "Disable" : "Enable")</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
