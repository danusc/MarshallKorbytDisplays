@page "{id:int?}"
@model MarshallDisplayRegistry.Pages.Displays.EditModel
@{
    ViewData["Title"] = Model.Input.Id.HasValue ? "Edit Display" : "Add Display";
}

<div class="page-title">
    <div>
        <h1 class="h3 mb-1">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">Display metadata and lifecycle state.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="Index">Back</a>
</div>

<form method="post" class="form-panel">
    <input type="hidden" asp-for="Input.Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Input.ComputerName" class="form-label"></label>
            <input asp-for="Input.ComputerName" class="form-control" />
            <span asp-validation-for="Input.ComputerName" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.FriendlyName" class="form-label"></label>
            <input asp-for="Input.FriendlyName" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.Location" class="form-label"></label>
            <input asp-for="Input.Location" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Input.Building" class="form-label"></label>
            <input asp-for="Input.Building" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Input.Room" class="form-label"></label>
            <input asp-for="Input.Room" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Input.SerialNumber" class="form-label"></label>
            <input asp-for="Input.SerialNumber" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Input.MacAddress" class="form-label"></label>
            <input asp-for="Input.MacAddress" class="form-control" />
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="Input.Enabled" class="form-check-input" />
                <label asp-for="Input.Enabled" class="form-check-label"></label>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" type="submit">Save</button>
        <a class="btn btn-outline-secondary" asp-page="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
