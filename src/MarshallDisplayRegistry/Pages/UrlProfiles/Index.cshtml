@page
@model MarshallDisplayRegistry.Pages.UrlProfiles.IndexModel
@{
    ViewData["Title"] = "URL Profiles";
}

<div class="page-title">
    <div>
        <h1 class="h3 mb-1">URL Profiles</h1>
        <p class="text-muted mb-0">Reusable allowed launch URLs.</p>
    </div>
    <a class="btn btn-primary" asp-page="Edit">Add Profile</a>
</div>

<div class="table-shell">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>URL</th>
                <th>Description</th>
                <th>Enabled</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var profile in Model.Profiles)
        {
            <tr>
                <td><strong>@profile.Name</strong></td>
                <td class="url-cell">@profile.Url</td>
                <td>@profile.Description</td>
                <td>@(profile.Enabled ? "Yes" : "No")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@profile.Id">Edit</a>
                    <form method="post" asp-page-handler="Toggle" asp-route-id="@profile.Id" class="d-inline">
                        <button class="btn btn-sm btn-outline-warning" type="submit">@(profile.Enabled ? "Disable" : "Enable")</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
